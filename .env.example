# OpenAI API key for name moderation
OPENAI_API_KEY=sk-your-key-here

# Server port (default 3000)
PORT=3000

# Base path for reverse proxy deployments (e.g. /htai/luckydrop)
# Leave empty for root deployments
NEXT_PUBLIC_BASE_PATH=

# --- Deployment (deploy.sh) ---
# SSH connection for remote deployment
DEPLOY_SERVER_USER=ubuntu
DEPLOY_SERVER_IP=your-server-ip
DEPLOY_SSH_KEY=~/.ssh/your-key.pem
DEPLOY_REMOTE_PATH=/var/www/your-site/luckydrop
DEPLOY_DOMAIN=your-domain.com

# --- PM2 (ecosystem.config.js) ---
PM2_LOG_DIR=/home/ubuntu/.pm2/logs

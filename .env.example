# OpenAI API key for name moderation
OPENAI_API_KEY=sk-your-key-here

# Server port (default 3000)
PORT=3000

# Base path for reverse proxy deployments (e.g. /htai/luckydrop)
# Leave empty for root deployments
NEXT_PUBLIC_BASE_PATH=

# --- Deployment (deploy.sh) ---
# SSH connection for remote deployment (AWS Lightsail)
DEPLOY_SERVER_USER=ubuntu
DEPLOY_SERVER_IP=34.212.8.221
DEPLOY_SSH_KEY=~/.ssh/lightsail-hanley-world.pem
DEPLOY_REMOTE_PATH=/var/www/hanley.world/htai/luckydrop
DEPLOY_DOMAIN=hanley.world

# --- PM2 (ecosystem.config.js) ---
PM2_LOG_DIR=/home/ubuntu/.pm2/logs
